{
  "agent": {
    "dock": "left",
    "thinking_display": "always_collapsed"
  },
  "agent_servers": {
    "opencode": {
      "default_config_options": {
        "mode": "build",
        "effort": "medium",
        "model": "opencode/mimo-v2.5-free"
      },
      "type": "registry"
    },
    "gemini": {
      "type": "registry"
    }
  },
  "auto_install_extensions": {
    "charmed-icons": true,
    "dockerfile": true,
    "emmet": true,
    "env": true,
    "git-firefly": true,
    "html": true,
    "lua": true,
    "mcp-server-context7": true,
    "rainbow-csv": true,
    "sql": true,
    "svelte": true,
    "toml": true,
    "vue": true,
    "zig": true
  },
  "auto_update": false,
  "buffer_font_fallbacks": ["ComicShannsMono Nerd Font"],
  "buffer_font_family": "Maple Mono NF",
  "buffer_font_features": {
    "cv02": true,
    "cv06": true,
    "cv07": true
  },
  "buffer_font_size": 14,
  "buffer_line_height": "comfortable",
  "buffer_font_weight": 500,
  "cli_default_open_behavior": "new_window",
  "colorize_brackets": true,
  "edit_predictions": {
    "copilot": {
      "proxy": null,
      "proxy_no_verify": null
    },
    "mode": "eager",
    "provider": "zed"
  },
  "file_types": {
    "Shell Script": ["Brewfile"]
  },
  "format_on_save": "off",
  "git": {
    "inline_blame": {
      "enabled": true,
      "show_commit_summary": true,
      "min_column": 50,
      "delay_ms": 500
    }
  },
  "icon_theme": {
    "mode": "dark",
    "light": "Base Charmed Icons",
    "dark": "Base Charmed Icons"
  },
  "indent_guides": {
    "active_line_width": 1,
    "coloring": "indent_aware",
    "line_width": 1
  },
  "languages": {
    "TypeScript": {
      "language_servers": ["vtsls"]
    }
  },
  "lsp": {
    "biome": {
      "settings": {
        "require_config_file": true
      }
    },
    "eslint": {
      "settings": {
        "onIgnoredFiles": "off"
      }
    },
    "tailwindcss-language-server": {
      "settings": {
        "files": {
          "exclude": ["**/components/ui/**"]
        },
        "experimental": {
          "classRegex": [
            "(?:\\w+ClassName)=\\s*['\"]([^'\"]*)['\"]"
          ]
        }
      }
    },
    "vscode-css-language-server": {
      "settings": {
        "css": {
          "lint": {
            "unknownAtRules": "ignore"
          }
        }
      }
    },
    "vtsls": {
      "enable_lsp_tasks": true,
      "settings": {
        "javascript": {
          "updateImportsOnFileMove": {
            "enabled": "always"
          }
        },
        "typescript": {
          "updateImportsOnFileMove": {
            "enabled": "always"
          }
        }
      }
    }
  },
  "minimap": {
    "show": "always"
  },
  "project_panel": {
    "dock": "right",
    "entry_spacing": "standard"
  },
  "search": {
    "case_sensitive": true
  },
  "tabs": {
    "file_icons": true,
    "git_status": true
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "terminal": {
    "cursor_shape": "underline",
    "line_height": {
      "custom": 1.2
    },
    "font_family": "Comic Code Ligatures",
    "font_size": 12
  },
  "theme": {
    "mode": "dark",
    "light": "Pace Dark",
    "dark": "Pace Dark"
  },
  "toolbar": {
    "breadcrumbs": true,
    "quick_actions": true
  },
  "ui_font_family": "Maple Mono NF",
  "ui_font_features": {
    "cv02": true,
    "cv06": true,
    "cv07": true
  },
  "ui_font_size": 14,
  "ui_font_weight": 500
}
