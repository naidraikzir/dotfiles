{
  "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
  "name": "Pace Dark",
  "author": "Fabian Hiller",
  "version": "0.3.0",
  "themes": [
    {
      "name": "Pace Dark",
      "appearance": "dark",
      "style": {
        "background": "#00000099",
        "background.appearance": "blurred",
        "border": "#00000000",
        "border.variant": "#00000000",
        "cursor": "#E2E8F0",
        "editor.active_line_number": "#CBD5E1",
        "editor.background": "#00000000",
        "editor.gutter.background": "#00000000",
        "editor.indent_guide": "#334155",
        "editor.indent_guide_active": "#64748B",
        "editor.line_highlight": "#1E293B",
        "editor.line_number": "#475569",
        "editor.selection": "#334155",
        "element.active": "#334155",
        "element.hover": "#1F2937",
        "element.selected": "#1F2937",
        "foreground": "#CBD5E1",
        "minimap.thumb.active_background": "#00000099",
        "minimap.thumb.background": "#00000099",
        "minimap.thumb.hover_background": "#00000099",
        "pane.focused_border": "#00000000",
        "panel.background": "#00000000",
        "panel.focused_border": "#00000000",
        "scrollbar.track.border": "#00000000",
        "search.match_background": "#ee229988",
        "status_bar.background": "#00000099",
        "status_bar.foreground": "#94A3B8",
        "syntax": {
          "attribute": {
            "color": "#34D399"
          },
          "comment": {
            "color": "#64748B"
          },
          "constant": {
            "color": "#2DD4BF"
          },
          "constructor": {
            "color": "#38BDF8"
          },
          "embedded": {
            "color": "#C084FC"
          },
          "function": {
            "color": "#34D399"
          },
          "keyword": {
            "color": "#F87171"
          },
          "link_text": {
            "color": "#38BDF8"
          },
          "link_uri": {
            "color": "#38BDF8",
            "font_style": "italic"
          },
          "number": {
            "color": "#C084FC"
          },
          "operator": {
            "color": "#F87171"
          },
          "property": {
            "color": "#CBD5E1"
          },
          "punctuation": {
            "color": "#94A3B8"
          },
          "punctuation.bracket": {
            "color": "#94A3B8"
          },
          "punctuation.delimiter": {
            "color": "#94A3B8"
          },
          "string": {
            "color": "#FDE68A"
          },
          "tag": {
            "color": "#F87171"
          },
          "type": {
            "color": "#2DD4BF"
          },
          "variable": {
            "color": "#38BDF8"
          },
          "variable.special": {
            "color": "#F87171"
          }
        },
        "tab.active_background": "#1F2937",
        "tab.border": "#1E293B",
        "tab.inactive_background": "#00000000",
        "tab_bar.background": "#00000000",
        "terminal.ansi.black": "#1E293B",
        "terminal.ansi.blue": "#3B82F6",
        "terminal.ansi.bright_black": "#64748B",
        "terminal.ansi.bright_blue": "#3B82F6",
        "terminal.ansi.bright_cyan": "#2DD4BF",
        "terminal.ansi.bright_green": "#34D399",
        "terminal.ansi.bright_magenta": "#86198F",
        "terminal.ansi.bright_red": "#EF4444",
        "terminal.ansi.bright_white": "#CBD5E1",
        "terminal.ansi.bright_yellow": "#FDE68A",
        "terminal.ansi.cyan": "#2DD4BF",
        "terminal.ansi.green": "#34D399",
        "terminal.ansi.magenta": "#C084FC",
        "terminal.ansi.red": "#F87171",
        "terminal.ansi.white": "#CBD5E1",
        "terminal.ansi.yellow": "#FDE68A",
        "terminal.background": "#111827",
        "terminal.foreground": "#94A3B8",
        "title_bar.background": "#00000099",
        "toolbar.background": "#00000000",
        "warning.background": "#999900"
      }
    }
  ]
}
